# Email Configuration

# Required for production email delivery
# Do not leave these values empty in Railway. Empty strings override defaults.
SMTP_ADDRESS=smtp.gmail.com
SMTP_PORT=587
SMTP_DOMAIN=example.com
SMTP_USER_NAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_ADDRESS=noreply@example.com

# Application host for email links (production)
APP_HOST=example.com

# Secret key base (generate with: bin/rails secret)
SECRET_KEY_BASE=your-secret-key-base-here
