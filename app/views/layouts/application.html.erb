<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Financial Planner" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Financial Planner">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if user_signed_in? %>
      <% sidebar_link_class = ->(path) do
           classes = [ "list-group-item", "list-group-item-action", "border-0", "rounded-0", "py-3" ]
           classes << "active" if current_page?(path)
           classes.join(" ")
         end %>

      <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
          <button
            class="btn btn-outline-light me-2"
            type="button"
            data-bs-toggle="offcanvas"
            data-bs-target="#mainSidebar"
            aria-controls="mainSidebar"
            aria-label="Mostrar u ocultar menu lateral"
          >
            <i class="bi bi-layout-sidebar-inset"></i>
            <span class="ms-1">Menu</span>
          </button>
          <%= link_to "Financial Planner", authenticated_root_path, class: "navbar-brand" %>
          <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto">
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                  <%= current_user.email %>
                </a>
                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarDropdown">
                  <li><%= link_to I18n.t("views.common.profile"), edit_user_registration_path, class: "dropdown-item" %></li>
                  <li><hr class="dropdown-divider"></li>
                  <li><%= link_to I18n.t("data_exports.show.title"), data_export_path, class: "dropdown-item" %></li>
                  <li><%= link_to I18n.t("data_imports.new.title"), new_data_import_path, class: "dropdown-item" %></li>
                  <li><hr class="dropdown-divider"></li>
                  <li><%= link_to "Cerrar Sesión", destroy_user_session_path, data: { turbo_method: :delete }, class: "dropdown-item" %></li>
                </ul>
              </li>
            </ul>
          </div>
        </div>
      </nav>
      <div class="container-fluid mt-4">
        <% if notice %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <%= notice %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        <% end %>

        <% if alert %>
          <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <%= alert %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        <% end %>

        <div class="row g-4 align-items-start">
          <aside class="col-12 col-lg-3 col-xl-2">
            <div class="offcanvas-lg offcanvas-start border rounded" tabindex="-1" id="mainSidebar" aria-labelledby="mainSidebarLabel">
              <div class="offcanvas-header border-bottom">
                <h5 class="offcanvas-title" id="mainSidebarLabel">Navegacion</h5>
                <button type="button" class="btn-close d-lg-none" data-bs-dismiss="offcanvas" data-bs-target="#mainSidebar" aria-label="Close"></button>
              </div>
              <div class="offcanvas-body p-0">
                <div class="list-group list-group-flush">
                  <%= link_to "Dashboard", authenticated_root_path, class: sidebar_link_class.call(authenticated_root_path) %>
                  <%= link_to "Cuentas", accounts_path, class: sidebar_link_class.call(accounts_path) %>
                  <%= link_to "Balance General", balance_sheets_path, class: sidebar_link_class.call(balance_sheets_path) %>
                  <%= link_to "Presupuestos", budgets_path, class: sidebar_link_class.call(budgets_path) %>
                  <%= link_to "Planes de Ahorro", savings_plans_path, class: sidebar_link_class.call(savings_plans_path) %>
                  <%= link_to "Reportes", reports_path, class: sidebar_link_class.call(reports_path) %>
                </div>
              </div>
            </div>
          </aside>
          <main class="col">
            <%= yield %>
          </main>
        </div>
      </div>
    <% else %>
      <div class="container-fluid mt-4">
        <% if notice %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <%= notice %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        <% end %>

        <% if alert %>
          <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <%= alert %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        <% end %>

        <%= yield %>
      </div>
    <% end %>
  </body>
</html>
