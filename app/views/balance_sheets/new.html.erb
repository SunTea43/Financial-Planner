<div class="row justify-content-center">
  <div class="col-md-12">
    <h1>Nuevo Balance General</h1>
    <p class="text-muted"><%= I18n.t("views.common.current_currency", currency: current_currency_code) %></p>
    
    <%= simple_form_for @balance_sheet do |f| %>
      <div class="card mb-4 shadow-sm">
        <div class="card-body">
          <div class="row">
            <div class="col-md-6">
              <%= f.input :account_id, collection: current_user.accounts, label_method: :name, value_method: :id, include_blank: "Sin cuenta específica", label: "Cuenta (opcional)" %>
            </div>
            <div class="col-md-6">
              <%= f.input :recorded_at, label: "Fecha y Hora de Registro", as: :string, input_html: { type: 'datetime-local', value: f.object.recorded_at&.strftime("%Y-%m-%dT%H:%M") || Time.current.strftime("%Y-%m-%dT%H:%M") } %>
            </div>
          </div>
          <%= f.input :notes, label: "Notas", as: :text, input_html: { rows: 2 } %>
        </div>
      </div>

      <div class="row">
        <div class="col-md-6" data-controller="nested-form">
          <template data-nested-form-target="template">
            <div class="card mb-3 asset-fields shadow-sm border-primary" data-new-record="true">
              <div class="card-body p-3">
                <div class="row g-2">
                  <div class="col-12">
                    <label class="form-label">Nombre</label>
                    <input type="text" name="balance_sheet[assets_attributes][NEW_RECORD][name]" class="form-control" placeholder="Nombre (ej: Efectivo)" />
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Tipo</label>
                    <select name="balance_sheet[assets_attributes][NEW_RECORD][item_type]" class="form-select">
                      <option value="">Seleccionar</option>
                      <option value="liquid">Líquido</option>
                      <option value="fixed">Fijo</option>
                    </select>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Monto</label>
                    <input type="number" step="0.01" name="balance_sheet[assets_attributes][NEW_RECORD][amount]" class="form-control" placeholder="Monto" />
                  </div>
                </div>
                <div class="mt-2">
                  <label class="form-label">Categoría</label>
                  <input type="text" name="balance_sheet[assets_attributes][NEW_RECORD][category]" class="form-control" placeholder="Categoría (opcional)" />
                </div>
                <div class="mt-2">
                  <label class="form-label">Descripción</label>
                  <textarea name="balance_sheet[assets_attributes][NEW_RECORD][description]" class="form-control" rows="1" placeholder="Descripción"></textarea>
                </div>
                <div class="text-end mt-2">
                  <button type="button" class="btn btn-sm btn-outline-danger" data-action="click->nested-form#remove">Eliminar</button>
                </div>
              </div>
            </div>
          </template>

          <div class="d-flex justify-content-between align-items-center mb-3">
            <h3 class="mb-0 text-primary">Activos</h3>
            <button type="button" class="btn btn-sm btn-outline-primary" data-action="click->nested-form#add">+ Agregar Activo</button>
          </div>
          
          <div id="assets" data-nested-form-target="container">
            <%= f.simple_fields_for :assets do |asset_form| %>
              <div class="card mb-3 asset-fields shadow-sm border-primary">
                <div class="card-body p-3">
                  <div class="row g-2">
                    <div class="col-12">
                      <%= asset_form.input :name, label: false, placeholder: "Nombre (ej: Efectivo)" %>
                    </div>
                    <div class="col-md-6">
                      <%= asset_form.input :item_type, label: false, collection: Asset::ASSET_TYPES, prompt: "Tipo" %>
                    </div>
                    <div class="col-md-6">
                      <%= asset_form.input :amount, label: false, as: :decimal, input_html: { step: 0.01 }, placeholder: "Monto" %>
                    </div>
                  </div>
                  <%= asset_form.input :category, label: false, placeholder: "Categoría (opcional)" %>
                  <%= asset_form.input :description, label: false, as: :text, input_html: { rows: 1 }, placeholder: "Descripción" %>
                  <% if asset_form.object.persisted? %>
                    <div class="text-end">
                      <%= asset_form.input :_destroy, as: :boolean, label: "Eliminar", wrapper_html: { class: "mb-0" } %>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>

        <div class="col-md-6" data-controller="nested-form">
          <template data-nested-form-target="template">
            <div class="card mb-3 liability-fields shadow-sm border-info" data-new-record="true">
              <div class="card-body p-3">
                <div class="row g-2">
                  <div class="col-12">
                    <label class="form-label">Nombre</label>
                    <input type="text" name="balance_sheet[liabilities_attributes][NEW_RECORD][name]" class="form-control" placeholder="Nombre (ej: Tarjeta)" />
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Tipo</label>
                    <select name="balance_sheet[liabilities_attributes][NEW_RECORD][item_type]" class="form-select">
                      <option value="">Seleccionar</option>
                      <option value="short_term">Corto Plazo</option>
                      <option value="long_term">Largo Plazo</option>
                    </select>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Monto</label>
                    <input type="number" step="0.01" name="balance_sheet[liabilities_attributes][NEW_RECORD][amount]" class="form-control" placeholder="Monto" />
                  </div>
                </div>
                <div class="mt-2">
                  <label class="form-label">Descripción</label>
                  <textarea name="balance_sheet[liabilities_attributes][NEW_RECORD][description]" class="form-control" rows="1" placeholder="Descripción"></textarea>
                </div>
                <div class="text-end mt-2">
                  <button type="button" class="btn btn-sm btn-outline-danger" data-action="click->nested-form#remove">Eliminar</button>
                </div>
              </div>
            </div>
          </template>

          <div class="d-flex justify-content-between align-items-center mb-3">
            <h3 class="mb-0 text-info">Pasivos</h3>
            <button type="button" class="btn btn-sm btn-outline-info" data-action="click->nested-form#add">+ Agregar Pasivo</button>
          </div>
          
          <div id="liabilities" data-nested-form-target="container">
            <%= f.simple_fields_for :liabilities do |liability_form| %>
              <div class="card mb-3 liability-fields shadow-sm border-info">
                <div class="card-body p-3">
                  <div class="row g-2">
                    <div class="col-12">
                      <%= liability_form.input :name, label: false, placeholder: "Nombre (ej: Tarjeta)" %>
                    </div>
                    <div class="col-md-6">
                      <%= liability_form.input :item_type, label: false, collection: Liability::LIABILITY_TYPES, prompt: "Tipo" %>
                    </div>
                    <div class="col-md-6">
                      <%= liability_form.input :amount, label: false, as: :decimal, input_html: { step: 0.01 }, placeholder: "Monto" %>
                    </div>
                  </div>
                  <%= liability_form.input :description, label: false, as: :text, input_html: { rows: 1 }, placeholder: "Descripción" %>
                  <% if liability_form.object.persisted? %>
                    <div class="text-end">
                      <%= liability_form.input :_destroy, as: :boolean, label: "Eliminar", wrapper_html: { class: "mb-0" } %>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <div class="sticky-bottom bg-white p-3 shadow-lg border-top mt-5 d-flex justify-content-between">
        <%= link_to "Cancelar", balance_sheets_path, class: "btn btn-secondary" %>
        <%= f.submit "Crear Balance General", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>

