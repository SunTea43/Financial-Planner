<div class="row mb-4">
  <div class="col-12">
    <div class="d-flex justify-content-between align-items-center">
      <div>
        <h1>Reporte de Balance General</h1>
        <p class="text-muted">Fecha de registro: <%= @balance_sheet.recorded_at.strftime("%d/%m/%Y %H:%M") %></p>
      </div>
      <div>
        <%= link_to "Volver", @balance_sheet, class: "btn btn-secondary" %>
        <%= link_to "Editar", edit_balance_sheet_path(@balance_sheet), class: "btn btn-primary" %>
      </div>
    </div>
  </div>
</div>

<div class="card mb-4">
  <div class="card-header">
    <h5 class="mb-0">Información General</h5>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-md-6">
        <p><strong>Cuenta:</strong> <%= @balance_sheet.account&.name || "Sin cuenta específica" %></p>
        <p><strong>Fecha y Hora:</strong> <%= @balance_sheet.recorded_at.strftime("%d de %B de %Y a las %H:%M") %></p>
      </div>
      <div class="col-md-6">
        <p><strong>Tipo de Cuenta:</strong> <%= @balance_sheet.account&.account_type&.humanize || "Sin especificar" %></p>
      </div>
    </div>
    <% if @balance_sheet.notes.present? %>
      <div class="row mt-2">
        <div class="col-12">
          <p><strong>Notas:</strong></p>
          <p class="text-muted"><%= @balance_sheet.notes %></p>
        </div>
      </div>
    <% end %>
  </div>
</div>

<% liquid_assets_list = @balance_sheet.assets.select { |a| a.item_type == 'liquid' } %>
<% liquid_assets_total = liquid_assets_list.sum(&:amount) %>
<% debt_to_assets = @balance_sheet.total_assets > 0 ? (@balance_sheet.total_liabilities.to_f / @balance_sheet.total_assets * 100) : nil %>
<% liquidity_ratio = @balance_sheet.total_liabilities > 0 ? (liquid_assets_total.to_f / @balance_sheet.total_liabilities) : nil %>
<% debt_to_equity = @balance_sheet.net_worth > 0 ? (@balance_sheet.total_liabilities.to_f / @balance_sheet.net_worth) : nil %>
<% liquid_asset_pct = @balance_sheet.total_assets > 0 ? (liquid_assets_total.to_f / @balance_sheet.total_assets * 100) : 0 %>

<div class="row mb-4">
  <div class="col-12">
    <div class="card">
      <div class="card-header bg-info text-white">
        <h5 class="mb-0">Resumen Ejecutivo</h5>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-4 col-lg-2 text-center border-end">
            <small class="text-muted d-block mb-1">Total Activos</small>
            <h4 class="text-success mb-0"><%= number_to_currency(@balance_sheet.total_assets) %></h4>
          </div>
          <div class="col-md-4 col-lg-2 text-center border-end">
            <small class="text-muted d-block mb-1">Total Pasivos</small>
            <h4 class="text-danger mb-0"><%= number_to_currency(@balance_sheet.total_liabilities) %></h4>
          </div>
          <div class="col-md-4 col-lg-2 text-center border-end">
            <small class="text-muted d-block mb-1">Patrimonio Neto</small>
            <h4 class="<%= @balance_sheet.net_worth >= 0 ? 'text-success' : 'text-danger' %> mb-0">
              <%= number_to_currency(@balance_sheet.net_worth) %>
            </h4>
          </div>
          <div class="col-md-4 col-lg-2 text-center border-end">
            <small class="text-muted d-block mb-1">Ratio Deuda/Activos</small>
            <% if debt_to_assets %>
              <h4 class="<%= debt_to_assets < 50 ? 'text-success' : 'text-warning' %> mb-0">
                <%= number_to_percentage(debt_to_assets, precision: 1) %>
              </h4>
              <small class="text-muted"><%= debt_to_assets < 50 ? 'Saludable' : 'Elevado' %></small>
            <% else %>
              <h4 class="text-muted mb-0">—</h4>
              <small class="text-muted">Sin activos</small>
            <% end %>
          </div>
          <div class="col-md-4 col-lg-2 text-center border-end">
            <small class="text-muted d-block mb-1">Ratio de Liquidez</small>
            <% if liquidity_ratio %>
              <h4 class="<%= liquidity_ratio >= 1 ? 'text-success' : 'text-danger' %> mb-0">
                <%= number_with_precision(liquidity_ratio, precision: 2) %>x
              </h4>
              <small class="text-muted"><%= liquidity_ratio >= 1 ? 'Cubre pasivos' : 'Insuficiente' %></small>
            <% else %>
              <h4 class="text-success mb-0">—</h4>
              <small class="text-muted">Sin pasivos</small>
            <% end %>
          </div>
          <div class="col-md-4 col-lg-2 text-center">
            <small class="text-muted d-block mb-1">Deuda/Patrimonio</small>
            <% if @balance_sheet.total_liabilities.zero? %>
              <h4 class="text-success mb-0">0x</h4>
              <small class="text-muted">Sin deuda</small>
            <% elsif @balance_sheet.net_worth <= 0 %>
              <h4 class="text-danger mb-0">N/A</h4>
              <small class="text-muted">Patrimonio negativo</small>
            <% else %>
              <h4 class="<%= debt_to_equity <= 1 ? 'text-success' : 'text-warning' %> mb-0">
                <%= number_with_precision(debt_to_equity, precision: 2) %>x
              </h4>
              <small class="text-muted"><%= debt_to_equity <= 1 ? 'Bajo apalancamiento' : 'Alto apalancamiento' %></small>
            <% end %>
          </div>
        </div>
        <div class="row mt-3">
          <div class="col-12">
            <div class="d-flex align-items-center gap-2 flex-wrap">
              <small class="text-muted">Activos Líquidos:</small>
              <strong><%= number_to_currency(liquid_assets_total) %></strong>
              <span class="badge bg-secondary"><%= number_to_percentage(liquid_asset_pct, precision: 1) %> del total</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<% if @balance_sheet.assets.any? || @balance_sheet.liabilities.any? %>
  <div class="row mb-4" data-controller="balance-sheet-pie-chart" data-balance-sheet-pie-chart-assets-data-value="<%= @assets_chart_data.to_json %>" data-balance-sheet-pie-chart-liabilities-data-value="<%= @liabilities_chart_data.to_json %>">
    <% if @balance_sheet.assets.any? %>
      <div class="col-md-6">
        <div class="card">
          <div class="card-body">
            <canvas id="assetsPieChart"></canvas>
          </div>
        </div>
      </div>
    <% end %>
    <% if @balance_sheet.liabilities.any? %>
      <div class="col-md-6">
        <div class="card">
          <div class="card-body">
            <canvas id="liabilitiesPieChart"></canvas>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

<% if @historical_chart_data && @historical_chart_data[:labels].length > 1 %>
  <div class="row mb-4" data-controller="balance-sheet-historical-chart" data-balance-sheet-historical-chart-historical-data-value="<%= @historical_chart_data.to_json %>">
    <div class="col-12">
      <div class="card">
        <div class="card-header">
          <h5 class="mb-0">Comportamiento Histórico</h5>
        </div>
        <div class="card-body">
          <canvas id="historicalLineChart" style="max-height: 400px;"></canvas>
        </div>
      </div>
    </div>
  </div>
<% end %>

<div class="row">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header">
        <h5 class="mb-0">Activos Líquidos</h5>
      </div>
      <div class="card-body">
        <% if liquid_assets_list.any? %>
          <% liquid_assets = liquid_assets_list %>
          <table class="table table-striped">
            <thead>
              <tr>
                <th>Nombre</th>
                <th>Categoría</th>
                <th class="text-end">Monto</th>
              </tr>
            </thead>
            <tbody>
              <% liquid_assets.each do |asset| %>
                <tr>
                  <td><%= asset.name %></td>
                  <td><%= asset.category || "N/A" %></td>
                  <td class="text-end"><strong><%= number_to_currency(asset.amount) %></strong></td>
                </tr>
              <% end %>
            </tbody>
            <tfoot>
              <tr class="table-primary">
                <th colspan="2">Subtotal Activos Líquidos</th>
                <th class="text-end"><%= number_to_currency(liquid_assets.sum(&:amount)) %></th>
              </tr>
            </tfoot>
          </table>
        <% else %>
          <p class="text-muted">No hay activos líquidos registrados.</p>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card">
      <div class="card-header">
        <h5 class="mb-0">Activos Fijos</h5>
      </div>
      <div class="card-body">
        <% fixed_assets = @balance_sheet.assets.select { |a| a.item_type == 'fixed' } %>
        <% if fixed_assets.any? %>
          <table class="table table-striped">
            <thead>
              <tr>
                <th>Nombre</th>
                <th>Categoría</th>
                <th class="text-end">Monto</th>
              </tr>
            </thead>
            <tbody>
              <% fixed_assets.each do |asset| %>
                <tr>
                  <td><%= asset.name %></td>
                  <td><%= asset.category || "N/A" %></td>
                  <td class="text-end"><strong><%= number_to_currency(asset.amount) %></strong></td>
                </tr>
              <% end %>
            </tbody>
            <tfoot>
              <tr class="table-primary">
                <th colspan="2">Subtotal Activos Fijos</th>
                <th class="text-end"><%= number_to_currency(fixed_assets.sum(&:amount)) %></th>
              </tr>
            </tfoot>
          </table>
        <% else %>
          <p class="text-muted">No hay activos fijos registrados.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="row mt-4">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header bg-warning">
        <h5 class="mb-0">Pasivos a Corto Plazo</h5>
      </div>
      <div class="card-body">
        <% short_term = @balance_sheet.liabilities.select { |l| l.item_type == 'short_term' } %>
        <% if short_term.any? %>
          <table class="table table-striped">
            <thead>
              <tr>
                <th>Nombre</th>
                <th class="text-end">Monto</th>
              </tr>
            </thead>
            <tbody>
              <% short_term.each do |liability| %>
                <tr>
                  <td><%= liability.name %></td>
                  <td class="text-end"><strong><%= number_to_currency(liability.amount) %></strong></td>
                </tr>
              <% end %>
            </tbody>
            <tfoot>
              <tr class="table-danger">
                <th>Subtotal Pasivos Corto Plazo</th>
                <th class="text-end"><%= number_to_currency(short_term.sum(&:amount)) %></th>
              </tr>
            </tfoot>
          </table>
        <% else %>
          <p class="text-muted">No hay pasivos a corto plazo registrados.</p>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card">
      <div class="card-header bg-danger text-white">
        <h5 class="mb-0">Pasivos a Largo Plazo</h5>
      </div>
      <div class="card-body">
        <% long_term = @balance_sheet.liabilities.select { |l| l.item_type == 'long_term' } %>
        <% if long_term.any? %>
          <table class="table table-striped">
            <thead>
              <tr>
                <th>Nombre</th>
                <th class="text-end">Monto</th>
              </tr>
            </thead>
            <tbody>
              <% long_term.each do |liability| %>
                <tr>
                  <td><%= liability.name %></td>
                  <td class="text-end"><strong><%= number_to_currency(liability.amount) %></strong></td>
                </tr>
              <% end %>
            </tbody>
            <tfoot>
              <tr class="table-danger">
                <th>Subtotal Pasivos Largo Plazo</th>
                <th class="text-end"><%= number_to_currency(long_term.sum(&:amount)) %></th>
              </tr>
            </tfoot>
          </table>
        <% else %>
          <p class="text-muted">No hay pasivos a largo plazo registrados.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>

<%= cell(BalanceSheetCell, @balance_sheet).call(:comparison) %>

<div class="row mt-4 mb-4">
  <div class="col-12 text-center">
    <button onclick="window.print()" class="btn btn-primary btn-lg">
      <i class="bi bi-printer"></i> Imprimir Reporte
    </button>
  </div>
</div>

