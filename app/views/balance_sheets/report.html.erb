<div class="row mb-4">
  <div class="col-12">
    <div class="d-flex justify-content-between align-items-center">
      <div>
        <h1>Reporte de Balance General</h1>
        <p class="text-muted">Fecha de registro: <%= @balance_sheet.recorded_at.strftime("%d/%m/%Y %H:%M") %></p>
      </div>
      <div>
        <%= link_to "Volver", @balance_sheet, class: "btn btn-secondary" %>
        <%= link_to "Editar", edit_balance_sheet_path(@balance_sheet), class: "btn btn-primary" %>
        <button onclick="window.print()" class="btn btn-outline-primary">
          <i class="bi bi-printer"></i> Imprimir
        </button>
      </div>
    </div>
  </div>
</div>

<div class="card mb-4">
  <div class="card-header">
    <h5 class="mb-0">Información General</h5>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-md-6">
        <p><strong>Cuenta:</strong> <%= @balance_sheet.account&.name || "Sin cuenta específica" %></p>
        <p><strong>Fecha y Hora:</strong> <%= @balance_sheet.recorded_at.strftime("%d de %B de %Y a las %H:%M") %></p>
      </div>
      <div class="col-md-6">
        <p><strong>Tipo de Cuenta:</strong> <%= @balance_sheet.account&.account_type&.humanize || "Sin especificar" %></p>
      </div>
    </div>
    <% if @balance_sheet.notes.present? %>
      <div class="row mt-2">
        <div class="col-12">
          <p><strong>Notas:</strong></p>
          <p class="text-muted"><%= @balance_sheet.notes %></p>
        </div>
      </div>
    <% end %>
  </div>
</div>

<% if @conversion_options_enabled %>
  <div class="card mb-4" id="assets-conversion-controls">
    <div class="card-header">
      <h5 class="mb-0"><%= I18n.t("views.balance_sheets.report.assets_conversion.title") %></h5>
    </div>
    <div class="card-body">
      <%= form_with(url: report_balance_sheet_path(@balance_sheet), method: :get, local: true, class: "row g-3 align-items-end") do %>
        <div class="col-md-6 col-lg-5">
          <%= label_tag :assets_conversion_factor, I18n.t("views.balance_sheets.report.assets_conversion.factor_label"), class: "form-label" %>
          <%= number_field_tag :assets_conversion_factor,
                @assets_conversion_factor_input.presence,
                min: 0.000001,
                step: 0.000001,
                class: "form-control",
                placeholder: I18n.t("views.balance_sheets.report.assets_conversion.factor_placeholder") %>
        </div>
        <div class="col-md-6 col-lg-5">
          <%= label_tag :assets_currency, I18n.t("views.balance_sheets.report.assets_conversion.currency_label"), class: "form-label" %>
          <%= select_tag :assets_currency,
                options_for_select([["—", ""]] + Account.currency_options, @assets_currency),
                class: "form-select" %>
        </div>
        <div class="col-12 col-lg-2 d-grid">
          <%= submit_tag I18n.t("views.balance_sheets.report.assets_conversion.apply_factor"), class: "btn btn-primary" %>
        </div>
        <div class="col-12">
          <div class="alert alert-warning mb-0 p-3">
            <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between gap-3 w-100">
              <div>
                <strong class="d-block"><%= I18n.t("views.balance_sheets.report.assets_conversion.update_title") %></strong>
                <small class="d-block"><%= I18n.t("views.balance_sheets.report.assets_conversion.alert_hint") %></small>
              </div>
              <div class="d-flex flex-wrap gap-2">
                <%= link_to I18n.t("views.balance_sheets.report.assets_conversion.update_values"),
                      refresh_exchange_rates_path(base_currency: @assets_base_currency),
                      data: { turbo_method: :post },
                      class: "btn btn-warning" %>
                <%= link_to I18n.t("views.balance_sheets.report.assets_conversion.reset"), report_balance_sheet_path(@balance_sheet), class: "btn btn-outline-secondary" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
      <small class="text-muted d-block mt-3">
        <%= I18n.t("views.balance_sheets.report.assets_conversion.current_factor", factor: number_with_precision(@assets_conversion_factor, precision: 6, strip_insignificant_zeros: true)) %>
      </small>
      <small class="text-muted d-block">
        <%= I18n.t("views.balance_sheets.report.assets_conversion.base_currency", currency: @assets_base_currency) %>
      </small>
    </div>
  </div>
<% end %>

<% liquid_assets_list = @balance_sheet.assets.select { |a| a.item_type == 'liquid' } %>
<% liquid_assets_total = liquid_assets_list.sum(&:amount) %>
<% conversion_factor = @assets_conversion_factor || BigDecimal("1") %>
<% converted_currency_options = converted_currency_format_options(@assets_currency) %>
<% conversion_enabled = @conversion_options_enabled %>
<% debt_to_assets_ratio = @balance_sheet.total_assets > 0 ? (@balance_sheet.total_liabilities / @balance_sheet.total_assets * 100) : nil %>
<% liquidity_ratio = @balance_sheet.total_liabilities > 0 ? (liquid_assets_total / @balance_sheet.total_liabilities) : nil %>
<% debt_to_equity = @balance_sheet.net_worth > 0 ? (@balance_sheet.total_liabilities / @balance_sheet.net_worth) : nil %>
<% liquid_asset_pct = @balance_sheet.total_assets > 0 ? (liquid_assets_total / @balance_sheet.total_assets * 100) : nil %>

<div class="row mb-4">
  <div class="col-12">
    <div class="card">
      <div class="card-header bg-info text-white">
        <h5 class="mb-0"><%= I18n.t("views.balance_sheets.report.executive_summary.title") %></h5>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-4 col-lg-2 text-center border-end">
            <small class="text-muted d-block mb-1"><%= BalanceSheet.human_attribute_name(:total_assets) %></small>
            <h4 class="text-success mb-0">
              <%= conversion_enabled ? number_to_currency(converted_asset_amount(@balance_sheet.total_assets, conversion_factor), converted_currency_options) : number_to_currency(@balance_sheet.total_assets) %>
            </h4>
          </div>
          <div class="col-md-4 col-lg-2 text-center border-end">
            <small class="text-muted d-block mb-1"><%= BalanceSheet.human_attribute_name(:total_liabilities) %></small>
            <h4 class="text-danger mb-0">
              <%= conversion_enabled ? number_to_currency(converted_asset_amount(@balance_sheet.total_liabilities, conversion_factor), converted_currency_options) : number_to_currency(@balance_sheet.total_liabilities) %>
            </h4>
          </div>
          <div class="col-md-4 col-lg-2 text-center border-end">
            <small class="text-muted d-block mb-1"><%= BalanceSheet.human_attribute_name(:net_worth) %></small>
            <h4 class="<%= @balance_sheet.net_worth >= 0 ? 'text-success' : 'text-danger' %> mb-0">
              <%= conversion_enabled ? number_to_currency(converted_asset_amount(@balance_sheet.net_worth, conversion_factor), converted_currency_options) : number_to_currency(@balance_sheet.net_worth) %>
            </h4>
          </div>
          <div class="col-md-4 col-lg-2 text-center border-end">
            <small class="text-muted d-block mb-1"><%= I18n.t("views.balance_sheets.report.executive_summary.debt_to_assets_ratio") %></small>
            <% if debt_to_assets_ratio %>
              <h4 class="<%= debt_to_assets_ratio < 50 ? 'text-success' : 'text-warning' %> mb-0">
                <%= number_to_percentage(debt_to_assets_ratio, precision: 1) %>
              </h4>
              <small class="text-muted"><%= debt_to_assets_ratio < 50 ? I18n.t("views.balance_sheets.report.executive_summary.healthy") : I18n.t("views.balance_sheets.report.executive_summary.elevated") %></small>
            <% else %>
              <h4 class="text-muted mb-0">—</h4>
              <small class="text-muted"><%= I18n.t("views.balance_sheets.report.executive_summary.no_assets") %></small>
            <% end %>
          </div>
          <div class="col-md-4 col-lg-2 text-center border-end">
            <small class="text-muted d-block mb-1"><%= I18n.t("views.balance_sheets.report.executive_summary.liquidity_ratio") %></small>
            <% if liquidity_ratio %>
              <h4 class="<%= liquidity_ratio >= 1 ? 'text-success' : 'text-danger' %> mb-0">
                <%= number_with_precision(liquidity_ratio, precision: 2) %>x
              </h4>
              <small class="text-muted"><%= liquidity_ratio >= 1 ? I18n.t("views.balance_sheets.report.executive_summary.covers_liabilities") : I18n.t("views.balance_sheets.report.executive_summary.insufficient") %></small>
            <% else %>
              <h4 class="text-success mb-0">—</h4>
              <small class="text-muted"><%= I18n.t("views.balance_sheets.report.executive_summary.no_liabilities") %></small>
            <% end %>
          </div>
          <div class="col-md-4 col-lg-2 text-center">
            <small class="text-muted d-block mb-1"><%= I18n.t("views.balance_sheets.report.executive_summary.debt_to_equity") %></small>
            <% if @balance_sheet.total_liabilities.zero? %>
              <h4 class="text-success mb-0">0x</h4>
              <small class="text-muted"><%= I18n.t("views.balance_sheets.report.executive_summary.no_debt") %></small>
            <% elsif @balance_sheet.net_worth <= 0 %>
              <h4 class="text-danger mb-0">N/A</h4>
              <small class="text-muted"><%= I18n.t("views.balance_sheets.report.executive_summary.negative_equity") %></small>
            <% else %>
              <h4 class="<%= debt_to_equity <= 1 ? 'text-success' : 'text-warning' %> mb-0">
                <%= number_with_precision(debt_to_equity, precision: 2) %>x
              </h4>
              <small class="text-muted"><%= debt_to_equity <= 1 ? I18n.t("views.balance_sheets.report.executive_summary.low_leverage") : I18n.t("views.balance_sheets.report.executive_summary.high_leverage") %></small>
            <% end %>
          </div>
        </div>
        <div class="row mt-3">
          <div class="col-12">
            <div class="d-flex align-items-center gap-2 flex-wrap">
              <small class="text-muted"><%= I18n.t("views.balance_sheets.report.executive_summary.liquid_assets") %>:</small>
              <strong>
                <%= conversion_enabled ? number_to_currency(converted_asset_amount(liquid_assets_total, conversion_factor), converted_currency_options) : number_to_currency(liquid_assets_total) %>
              </strong>
              <% if liquid_asset_pct %>
                <span class="badge bg-secondary"><%= number_to_percentage(liquid_asset_pct, precision: 1) %> <%= I18n.t("views.balance_sheets.report.executive_summary.of_total") %></span>
              <% else %>
                <span class="badge bg-secondary">— <%= I18n.t("views.balance_sheets.report.executive_summary.no_assets") %></span>
              <% end %>
            </div>
          </div>
        </div>
        <% if conversion_enabled %>
          <div class="row mt-2" id="converted-assets-summary">
            <div class="col-md-3">
              <small class="text-muted d-block"><%= I18n.t("views.balance_sheets.report.assets_conversion.converted_total_assets") %></small>
              <strong class="text-primary"><%= number_to_currency(converted_asset_amount(@balance_sheet.total_assets, conversion_factor), converted_currency_options) %></strong>
            </div>
            <div class="col-md-3">
              <small class="text-muted d-block"><%= I18n.t("views.balance_sheets.report.assets_conversion.converted_liquid_assets") %></small>
              <strong class="text-primary"><%= number_to_currency(converted_asset_amount(liquid_assets_total, conversion_factor), converted_currency_options) %></strong>
            </div>
            <div class="col-md-3">
              <small class="text-muted d-block"><%= I18n.t("views.balance_sheets.report.assets_conversion.converted_total_liabilities") %></small>
              <strong class="text-primary"><%= number_to_currency(converted_asset_amount(@balance_sheet.total_liabilities, conversion_factor), converted_currency_options) %></strong>
            </div>
            <div class="col-md-3">
              <small class="text-muted d-block"><%= I18n.t("views.balance_sheets.report.assets_conversion.converted_net_worth") %></small>
              <strong class="text-primary"><%= number_to_currency(converted_asset_amount(@balance_sheet.net_worth, conversion_factor), converted_currency_options) %></strong>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<% if @balance_sheet.assets.any? || @balance_sheet.liabilities.any? %>
  <div class="row mb-4" data-controller="balance-sheet-pie-chart" data-balance-sheet-pie-chart-assets-data-value="<%= @assets_chart_data.to_json %>" data-balance-sheet-pie-chart-liabilities-data-value="<%= @liabilities_chart_data.to_json %>">
    <% if @balance_sheet.assets.any? %>
      <div class="col-md-6">
        <div class="card">
          <div class="card-body">
            <canvas id="assetsPieChart"></canvas>
          </div>
        </div>
      </div>
    <% end %>
    <% if @balance_sheet.liabilities.any? %>
      <div class="col-md-6">
        <div class="card">
          <div class="card-body">
            <canvas id="liabilitiesPieChart"></canvas>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

<% if @historical_chart_data && @historical_chart_data[:labels].length > 1 %>
  <div class="row mb-4" data-controller="balance-sheet-historical-chart" data-balance-sheet-historical-chart-historical-data-value="<%= @historical_chart_data.to_json %>">
    <div class="col-12">
      <div class="card">
        <div class="card-header">
          <h5 class="mb-0"><%= I18n.t("views.balance_sheets.report.historical_behavior") %></h5>
        </div>
        <div class="card-body">
          <canvas id="historicalLineChart" style="max-height: 400px;"></canvas>
        </div>
      </div>
    </div>
  </div>
<% end %>

<div class="row">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header">
        <h5 class="mb-0"><%= I18n.t("views.balance_sheets.report.liquid_assets_section") %></h5>
      </div>
      <div class="card-body">
        <% liquid_assets = @balance_sheet.assets.select { |a| a.item_type == 'liquid' } %>
        <% if liquid_assets.any? %>
          <table class="table table-striped">
            <thead>
              <tr>
                <th><%= I18n.t("views.balance_sheets.report.table.name") %></th>
                <th><%= I18n.t("views.balance_sheets.report.table.category") %></th>
                <th class="text-end"><%= I18n.t("views.balance_sheets.report.table.amount") %></th>
                <% if conversion_enabled %>
                  <th class="text-end"><%= I18n.t("views.balance_sheets.report.table.converted_amount") %></th>
                <% end %>
              </tr>
            </thead>
            <tbody>
              <% liquid_assets.each do |asset| %>
                <tr>
                  <td><%= asset.name %></td>
                  <td><%= asset.category.presence || I18n.t("views.balance_sheets.report.table.no_category") %></td>
                  <td class="text-end"><strong><%= number_to_currency(asset.amount) %></strong></td>
                  <% if conversion_enabled %>
                    <td class="text-end"><strong><%= number_to_currency(converted_asset_amount(asset.amount, conversion_factor), converted_currency_options) %></strong></td>
                  <% end %>
                </tr>
              <% end %>
            </tbody>
            <tfoot>
              <tr class="table-primary">
                <th colspan="2"><%= I18n.t("views.balance_sheets.report.table.subtotal_liquid") %></th>
                <th class="text-end"><%= number_to_currency(liquid_assets.sum(&:amount)) %></th>
                <% if conversion_enabled %>
                  <th class="text-end"><%= number_to_currency(converted_asset_amount(liquid_assets.sum(&:amount), conversion_factor), converted_currency_options) %></th>
                <% end %>
              </tr>
            </tfoot>
          </table>
        <% else %>
          <p class="text-muted"><%= I18n.t("views.balance_sheets.report.empty.liquid_assets") %></p>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card">
      <div class="card-header">
        <h5 class="mb-0"><%= I18n.t("views.balance_sheets.report.fixed_assets_section") %></h5>
      </div>
      <div class="card-body">
        <% fixed_assets = @balance_sheet.assets.select { |a| a.item_type == 'fixed' } %>
        <% if fixed_assets.any? %>
          <table class="table table-striped">
            <thead>
              <tr>
                <th><%= I18n.t("views.balance_sheets.report.table.name") %></th>
                <th><%= I18n.t("views.balance_sheets.report.table.category") %></th>
                <th class="text-end"><%= I18n.t("views.balance_sheets.report.table.amount") %></th>
                <% if conversion_enabled %>
                  <th class="text-end"><%= I18n.t("views.balance_sheets.report.table.converted_amount") %></th>
                <% end %>
              </tr>
            </thead>
            <tbody>
              <% fixed_assets.each do |asset| %>
                <tr>
                  <td><%= asset.name %></td>
                  <td><%= asset.category.presence || I18n.t("views.balance_sheets.report.table.no_category") %></td>
                  <td class="text-end"><strong><%= number_to_currency(asset.amount) %></strong></td>
                  <% if conversion_enabled %>
                    <td class="text-end"><strong><%= number_to_currency(converted_asset_amount(asset.amount, conversion_factor), converted_currency_options) %></strong></td>
                  <% end %>
                </tr>
              <% end %>
            </tbody>
            <tfoot>
              <tr class="table-primary">
                <th colspan="2"><%= I18n.t("views.balance_sheets.report.table.subtotal_fixed") %></th>
                <th class="text-end"><%= number_to_currency(fixed_assets.sum(&:amount)) %></th>
                <% if conversion_enabled %>
                  <th class="text-end"><%= number_to_currency(converted_asset_amount(fixed_assets.sum(&:amount), conversion_factor), converted_currency_options) %></th>
                <% end %>
              </tr>
            </tfoot>
          </table>
        <% else %>
          <p class="text-muted"><%= I18n.t("views.balance_sheets.report.empty.fixed_assets") %></p>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="row mt-4">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header bg-warning">
        <h5 class="mb-0"><%= I18n.t("views.balance_sheets.report.short_term_liabilities_section") %></h5>
      </div>
      <div class="card-body">
        <% short_term = @balance_sheet.liabilities.select { |l| l.item_type == 'short_term' } %>
