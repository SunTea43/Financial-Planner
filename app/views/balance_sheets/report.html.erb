                <th><%= I18n.t("views.balance_sheets.report.table.name") %></th>
                <th class="text-end"><%= I18n.t("views.balance_sheets.report.table.amount") %></th>
                <% if conversion_enabled %>
                  <th class="text-end"><%= I18n.t("views.balance_sheets.report.table.converted_amount") %></th>
                <% end %>
              </tr>
            </thead>
            <tbody>
              <% short_term.each do |liability| %>
                <tr>
                  <td><%= liability.name %></td>
                  <td class="text-end"><strong><%= number_to_currency(liability.amount) %></strong></td>
                  <% if conversion_enabled %>
                    <td class="text-end"><strong><%= number_to_currency(converted_asset_amount(liability.amount, conversion_factor), converted_currency_options) %></strong></td>
                  <% end %>
                </tr>
              <% end %>
            </tbody>
            <tfoot>
              <tr class="table-danger">
                <th><%= I18n.t("views.balance_sheets.report.table.subtotal_short_term") %></th>
                <th class="text-end"><%= number_to_currency(short_term.sum(&:amount)) %></th>
                <% if conversion_enabled %>
                  <th class="text-end"><%= number_to_currency(converted_asset_amount(short_term.sum(&:amount), conversion_factor), converted_currency_options) %></th>
                <% end %>
              </tr>
            </tfoot>
          </table>
        <% else %>
          <p class="text-muted"><%= I18n.t("views.balance_sheets.report.empty.short_term") %></p>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card">
      <div class="card-header bg-danger text-white">
        <h5 class="mb-0"><%= I18n.t("views.balance_sheets.report.long_term_liabilities_section") %></h5>
      </div>
      <div class="card-body">
        <% long_term = @balance_sheet.liabilities.select { |l| l.item_type == 'long_term' } %>
        <% if long_term.any? %>
          <table class="table table-striped">
            <thead>
              <tr>
                <th><%= I18n.t("views.balance_sheets.report.table.name") %></th>
                <th class="text-end"><%= I18n.t("views.balance_sheets.report.table.amount") %></th>
                <% if conversion_enabled %>
                  <th class="text-end"><%= I18n.t("views.balance_sheets.report.table.converted_amount") %></th>
                <% end %>
              </tr>
            </thead>
            <tbody>
              <% long_term.each do |liability| %>
                <tr>
                  <td><%= liability.name %></td>
                  <td class="text-end"><strong><%= number_to_currency(liability.amount) %></strong></td>
                  <% if conversion_enabled %>
                    <td class="text-end"><strong><%= number_to_currency(converted_asset_amount(liability.amount, conversion_factor), converted_currency_options) %></strong></td>
                  <% end %>
                </tr>
              <% end %>
            </tbody>
            <tfoot>
              <tr class="table-danger">
                <th><%= I18n.t("views.balance_sheets.report.table.subtotal_long_term") %></th>
                <th class="text-end"><%= number_to_currency(long_term.sum(&:amount)) %></th>
                <% if conversion_enabled %>
                  <th class="text-end"><%= number_to_currency(converted_asset_amount(long_term.sum(&:amount), conversion_factor), converted_currency_options) %></th>
                <% end %>
              </tr>
            </tfoot>
          </table>
        <% else %>
          <p class="text-muted"><%= I18n.t("views.balance_sheets.report.empty.long_term") %></p>
        <% end %>
      </div>
    </div>
  </div>
</div>

<%= render(BalanceSheets::ComparisonComponent.new(balance_sheet: @balance_sheet)) %>

