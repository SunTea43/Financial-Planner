<div class="row justify-content-center">
  <div class="col-md-6 col-lg-4">
    <div class="card shadow-sm mt-5">
      <div class="card-body p-4">
        <h2 class="card-title text-center mb-4"><%= I18n.t('devise.registrations.new.sign_up', default: 'Registrarse') %></h2>

        <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
          <%= f.error_notification %>

          <div class="form-inputs mb-3">
            <%= f.input :email,
                        required: true,
                        autofocus: true,
                        input_html: { autocomplete: "email" }%>
            <%= f.input :preferred_currency,
                        collection: User.currency_options,
                        include_blank: false,
                        label: I18n.t("devise.registrations.new.preferred_currency"),
                        hint: I18n.t("devise.registrations.new.preferred_currency_hint") %>
            <%= f.input :password,
                        required: true,
                        hint: ("#{@minimum_password_length} characters minimum" if @minimum_password_length),
                        input_html: { autocomplete: "new-password" } %>
            <%= f.input :password_confirmation,
                        required: true,
                        input_html: { autocomplete: "new-password" } %>
          </div>

          <div class="form-actions d-grid gap-2 mb-3">
            <%= f.button :submit, I18n.t('devise.registrations.new.sign_up', default: "Registrarse"), class: "btn btn-primary btn-lg" %>
          </div>
        <% end %>

        <div class="text-center mt-3">
          <%= render "devise/shared/links" %>
        </div>
      </div>
    </div>
  </div>
</div>
