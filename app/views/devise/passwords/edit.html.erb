<div class="row justify-content-center">
  <div class="col-md-6 col-lg-4">
    <div class="card shadow-sm mt-5">
      <div class="card-body p-4">
        <h2 class="card-title text-center mb-4"><%= I18n.t('devise.passwords.edit.change_your_password', default: 'Cambiar tu contraseña') %></h2>

        <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
          <%= f.error_notification %>

          <%= f.input :reset_password_token, as: :hidden %>
          <%= f.full_error :reset_password_token %>

          <div class="form-inputs mb-3">
            <%= f.input :password,
                        label: I18n.t('devise.passwords.edit.new_password', default: "Nueva contraseña"),
                        required: true,
                        autofocus: true,
                        hint: ("#{@minimum_password_length} caracteres como mínimo" if @minimum_password_length),
                        input_html: { autocomplete: "new-password" } %>
            <%= f.input :password_confirmation,
                        label: I18n.t('devise.passwords.edit.confirm_new_password', default: "Confirmar nueva contraseña"),
                        required: true,
                        input_html: { autocomplete: "new-password" } %>
          </div>

          <div class="form-actions d-grid gap-2 mb-3">
            <%= f.button :submit, I18n.t('devise.passwords.edit.change_my_password', default: "Cambiar mi contraseña"), class: "btn btn-primary btn-lg" %>
          </div>
        <% end %>

        <div class="text-center mt-3">
          <%= render "devise/shared/links" %>
        </div>
      </div>
    </div>
  </div>
</div>
