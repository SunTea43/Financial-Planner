<div class="row justify-content-center">
  <div class="col-md-10 col-lg-8">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h1 class="h2 mb-1">Historial: <span class="text-primary"><%= @asset.name %></span></h1>
        <p class="text-muted mb-0">
          <%= @asset.item_type.humanize %> &bull; 
          <%= @asset.category.present? ? @asset.category.humanize : "Sin categoría" %>
        </p>
      </div>
      <%= link_to "Volver", balance_sheet_path(@balance_sheet), class: "btn btn-outline-secondary" %>
    </div>

    <div class="card shadow-sm border-0">
      <div class="card-body p-4">
        <canvas data-controller="chart"
          data-chart-data-value="<%= @chart_data.to_json %>"
          style="max-height: 400px;">
        </canvas>
      </div>
    </div>
    <div class="card shadow-sm border-0 mt-4">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>Fecha de Balance</th>
                <th class="text-end">Monto</th>
              </tr>
            </thead>
            <tbody>
              <% @asset_history.sort_by { |date, _| date }.reverse.each do |date, amount| %>
                <tr>
                  <td><%= date.strftime("%Y-%m-%d") %></td>
                  <td class="text-end text-success"><%= number_to_currency(amount) %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
    
    <div class="mt-4 text-center text-muted small">
      <p>Mostrando historial desde el primer balance registrado hasta <%= @balance_sheet.recorded_at.strftime("%d/%m/%Y") %></p>
    </div>
  </div>
</div>
