<div class="row mb-4">
  <div class="col-12">
    <h1><%= t("data_exports.show.title") %></h1>
    <p class="text-muted"><%= t("data_exports.show.subtitle") %></p>
  </div>
</div>

<div class="row">
  <div class="col-md-8 mx-auto">
    <div class="card">
      <div class="card-header">
        <h5 class="mb-0"><%= t("data_exports.show.card_title") %></h5>
      </div>
      <div class="card-body">
        <p>
          <%= t("data_exports.show.description") %>
        </p>

        <div class="alert alert-info">
          <i class="bi bi-info-circle"></i>
          <%= raw t("data_exports.show.warning_html") %>
        </div>

        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
          <%= button_to data_export_path, method: :post, class: "btn btn-primary", data: { turbo: false } do %>
            <i class="bi bi-download"></i> <%= t("data_exports.show.submit") %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
