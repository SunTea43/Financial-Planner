<div class="row justify-content-center">
  <div class="col-md-10">
    <h1><%= I18n.t('views.budgets.edit.new_title') %></h1>
    
    <%= simple_form_for @budget do |f| %>
      <div class="card mb-4">
        <div class="card-body">
          <div class="row">
            <div class="col-md-4">
              <%= f.input :account_id, collection: current_user.accounts, label_method: :name, value_method: :id, include_blank: I18n.t('views.common.none_specific'), label: Budget.human_attribute_name(:account_id) %>
            </div>
            <div class="col-md-4">
              <%= f.input :name, label: Budget.human_attribute_name(:name) %>
            </div>
            <div class="col-md-4">
              <%= f.input :periodicity, label: Budget.human_attribute_name(:periodicity), collection: Budget.translated_periodicities, selected: 'monthly' %>
            </div>
          </div>
          <div class="row mt-2">
            <div class="col-md-6">
              <%= f.input :start_date, label: Budget.human_attribute_name(:start_date), as: :date %>
            </div>
            <div class="col-md-6">
              <%= f.input :end_date, label: Budget.human_attribute_name(:end_date), as: :date %>
            </div>
          </div>
        </div>
      </div>

      <div class="row">
        <div class="col-md-6" data-controller="nested-form">
          <template data-nested-form-target="template">
            <div class="card mb-3 income-item shadow-sm border-success" data-new-record="true">
              <div class="card-body p-3">
                <div class="row g-2">
                  <div class="col-md-7">
                    <label class="form-label">Nombre</label>
                    <input type="text" name="budget[budget_items_attributes][NEW_RECORD][name]" class="form-control" placeholder="Nombre (ej: Salario)" />
                  </div>
                  <div class="col-md-5">
                    <label class="form-label">Monto</label>
                    <input type="number" step="0.01" name="budget[budget_items_attributes][NEW_RECORD][amount]" class="form-control" placeholder="Monto" />
                  </div>
                </div>
                <input type="hidden" name="budget[budget_items_attributes][NEW_RECORD][item_type]" value="income" />
                <textarea name="budget[budget_items_attributes][NEW_RECORD][description]" class="form-control mt-2" rows="1" placeholder="Descripción (opcional)"></textarea>
                <div class="text-end mt-2">
                  <button type="button" class="btn btn-sm btn-outline-danger" data-action="click->nested-form#remove">Eliminar</button>
                </div>
              </div>
            </div>
          </template>

          <div class="d-flex justify-content-between align-items-center mb-3">
            <h3 class="mb-0 text-success"><%= I18n.t('views.budgets.edit.income_section') %></h3>
            <button type="button" class="btn btn-sm btn-outline-success" data-action="click->nested-form#add">+ <%= I18n.t('views.budgets.edit.add_income') %></button>
          </div>
          
          <div id="income-items" data-nested-form-target="container">
            <%= f.simple_fields_for :budget_items do |item_form| %>
              <% if item_form.object.item_type == 'income' || (!item_form.object.persisted? && item_form.object.item_type != 'expense') %>
                <div class="card mb-3 income-item shadow-sm border-success">
                  <div class="card-body p-3">
                    <div class="row g-2">
                      <div class="col-md-7">
                        <%= item_form.input :name, label: false, placeholder: "Nombre (ej: Salario)" %>
                      </div>
                      <div class="col-md-5">
                        <%= item_form.input :amount, label: false, as: :decimal, input_html: { step: 0.01 }, placeholder: "Monto" %>
                      </div>
                    </div>
                    <%= item_form.input :description, label: false, as: :text, input_html: { rows: 1 }, placeholder: "Descripción (opcional)" %>
                    <% if item_form.object.persisted? %>
                      <div class="text-end">
                        <%= item_form.input :_destroy, as: :boolean, label: "Eliminar", wrapper_html: { class: "mb-0" } %>
                        <%= item_form.input :id, as: :hidden %>
                      </div>
                    <% end %>
                    <%= item_form.input :item_type, as: :hidden, input_html: { value: 'income' } %>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>

        <div class="col-md-6" data-controller="nested-form">
          <template data-nested-form-target="template">
            <div class="card mb-3 expense-item shadow-sm border-danger" data-new-record="true">
              <div class="card-body p-3">
                <div class="row g-2">
                  <div class="col-md-7">
                    <label class="form-label">Nombre</label>
                    <input type="text" name="budget[budget_items_attributes][NEW_RECORD][name]" class="form-control" placeholder="Nombre (ej: Alquiler)" />
                  </div>
                  <div class="col-md-5">
                    <label class="form-label">Monto</label>
                    <input type="number" step="0.01" name="budget[budget_items_attributes][NEW_RECORD][amount]" class="form-control" placeholder="Monto" />
                  </div>
                </div>
                <input type="hidden" name="budget[budget_items_attributes][NEW_RECORD][item_type]" value="expense" />
                <textarea name="budget[budget_items_attributes][NEW_RECORD][description]" class="form-control mt-2" rows="1" placeholder="Descripción (opcional)"></textarea>
                <div class="text-end mt-2">
                  <button type="button" class="btn btn-sm btn-outline-danger" data-action="click->nested-form#remove">Eliminar</button>
                </div>
              </div>
            </div>
          </template>

          <div class="d-flex justify-content-between align-items-center mb-3">
            <h3 class="mb-0 text-danger"><%= I18n.t('views.budgets.edit.expense_section') %></h3>
            <button type="button" class="btn btn-sm btn-outline-danger" data-action="click->nested-form#add">+ <%= I18n.t('views.budgets.edit.add_expense') %></button>
          </div>
          
          <div id="expense-items" data-nested-form-target="container">
            <%= f.simple_fields_for :budget_items do |item_form| %>
              <% if item_form.object.item_type == 'expense' %>
                <div class="card mb-3 expense-item shadow-sm border-danger">
                  <div class="card-body p-3">
                    <div class="row g-2">
                      <div class="col-md-7">
                        <%= item_form.input :name, label: false, placeholder: "Nombre (ej: Alquiler)" %>
                      </div>
                      <div class="col-md-5">
                        <%= item_form.input :amount, label: false, as: :decimal, input_html: { step: 0.01 }, placeholder: "Monto" %>
                      </div>
                    </div>
                    <%= item_form.input :description, label: false, as: :text, input_html: { rows: 1 }, placeholder: "Descripción (opcional)" %>
                    <% if item_form.object.persisted? %>
                      <div class="text-end">
                        <%= item_form.input :_destroy, as: :boolean, label: "Eliminar", wrapper_html: { class: "mb-0" } %>
                        <%= item_form.input :id, as: :hidden %>
                      </div>
                    <% end %>
                    <%= item_form.input :item_type, as: :hidden, input_html: { value: 'expense' } %>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>

      <div class="sticky-bottom bg-white p-3 shadow-lg border-top mt-5 d-flex justify-content-between">
        <%= link_to I18n.t('views.budgets.edit.cancel'), budgets_path, class: "btn btn-secondary" %>
        <%= f.submit I18n.t('views.budgets.edit.submit_create'), class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>

