<div class="row justify-content-center">
  <div class="col-md-10">
    <h1><%= I18n.t('views.budgets.edit.new_title') %></h1>
    <p class="text-muted"><%= I18n.t("views.common.current_currency", currency: current_currency_code) %></p>
    
    <%= simple_form_for @budget do |f| %>
      <datalist id="budget-category-options">
        <% @budget_categories.each do |category| %>
          <option value="<%= category %>"></option>
        <% end %>
      </datalist>

      <div class="card mb-4">
        <div class="card-body">
          <div class="row">
            <div class="col-md-4">
              <%= f.input :account_id, collection: current_user.accounts, label_method: :name, value_method: :id, include_blank: I18n.t('views.common.none_specific'), label: Budget.human_attribute_name(:account_id) %>
            </div>
            <div class="col-md-4">
              <%= f.input :name, label: Budget.human_attribute_name(:name) %>
            </div>
            <div class="col-md-4">
              <%= f.input :periodicity, label: Budget.human_attribute_name(:periodicity), collection: Budget.translated_periodicities, selected: 'monthly' %>
            </div>
          </div>
          <div class="row mt-2">
            <div class="col-md-6">
              <%= f.input :start_date, label: Budget.human_attribute_name(:start_date), as: :date %>
            </div>
            <div class="col-md-6">
              <%= f.input :end_date, label: Budget.human_attribute_name(:end_date), as: :date %>
            </div>
          </div>
        </div>
      </div>

      <div class="row">
        <div class="col-md-6" data-controller="nested-form">
          <template data-nested-form-target="template">
            <div class="card mb-3 income-item nested-fields shadow-sm border-success" data-new-record="true">
              <div class="card-header drag-handle d-flex justify-content-between align-items-center py-1" style="cursor: move;">
                <span class="text-muted small">☰ <%= I18n.t('views.budgets.edit.reorder') %></span>
                <button type="button" class="btn-close btn-close-sm" data-action="click->nested-form#remove" aria-label="Close"></button>
              </div>
              <div class="card-body p-3">
                <div class="row g-2">
                  <div class="col-md-7">
                    <label class="form-label"><%= BudgetItem.human_attribute_name(:name) %></label>
                    <input type="text" name="budget[budget_items_attributes][NEW_RECORD][name]" class="form-control" placeholder="<%= BudgetItem.human_attribute_name(:name) %>" />
                  </div>
                  <div class="col-md-5">
                    <label class="form-label"><%= BudgetItem.human_attribute_name(:amount) %></label>
                    <input type="number" step="0.01" name="budget[budget_items_attributes][NEW_RECORD][amount]" class="form-control" placeholder="<%= BudgetItem.human_attribute_name(:amount) %>" />
                  </div>
                </div>
                <input type="hidden" name="budget[budget_items_attributes][NEW_RECORD][item_type]" value="income" />
                <input type="hidden" name="budget[budget_items_attributes][NEW_RECORD][position]" value="999" />
                <input type="text" name="budget[budget_items_attributes][NEW_RECORD][category]" class="form-control mt-2" placeholder="<%= BudgetItem.human_attribute_name(:category) %>" list="budget-category-options" />
                <textarea name="budget[budget_items_attributes][NEW_RECORD][description]" class="form-control mt-2" rows="1" placeholder="<%= BudgetItem.human_attribute_name(:description) %>"></textarea>
              </div>
            </div>
          </template>

          <div class="d-flex justify-content-between align-items-center mb-3">
            <h3 class="mb-0 text-success"><%= I18n.t('views.budgets.edit.income_section') %></h3>
            <button type="button" class="btn btn-sm btn-outline-success" data-action="click->nested-form#add">+ <%= I18n.t('views.budgets.edit.add_income') %></button>
          </div>
          <p class="small text-muted"><%= I18n.t("views.budgets.edit.category_help") %></p>

          <div id="income-items" data-controller="sortable" data-nested-form-target="container">
            <%= f.simple_fields_for :budget_items do |item_form| %>
              <% if item_form.object.item_type == 'income' || (!item_form.object.persisted? && item_form.object.item_type != 'expense') %>
                <div class="card mb-3 income-item nested-fields shadow-sm border-success" data-new-record="<%= item_form.object.persisted? ? 'false' : 'true' %>">
                  <div class="card-header drag-handle d-flex justify-content-between align-items-center py-1" style="cursor: move;">
                    <span class="text-muted small">☰ <%= I18n.t('views.budgets.edit.reorder') %></span>
                    <button type="button" class="btn-close btn-close-sm" data-action="click->nested-form#remove" aria-label="Close"></button>
                  </div>
                  <div class="card-body p-3">
                    <div class="row g-2">
                      <div class="col-md-7">
                        <%= item_form.input :name, label: false, placeholder: BudgetItem.human_attribute_name(:name) %>
                      </div>
                      <div class="col-md-5">
                        <%= item_form.input :amount, label: false, as: :decimal, input_html: { step: 0.01 }, placeholder: BudgetItem.human_attribute_name(:amount) %>
                      </div>
                    </div>
                    <%= item_form.input :category, label: false, placeholder: BudgetItem.human_attribute_name(:category), input_html: { list: "budget-category-options" } %>
                    <%= item_form.input :description, label: false, as: :text, input_html: { rows: 1 }, placeholder: BudgetItem.human_attribute_name(:description) %>
                    <%= item_form.input :item_type, as: :hidden, input_html: { value: 'income' } %>
                    <%= item_form.input :position, as: :hidden %>
                    <%= item_form.input :id, as: :hidden if item_form.object.persisted? %>
                    <%= item_form.input :_destroy, as: :hidden %>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>

        <div class="col-md-6" data-controller="nested-form">
          <template data-nested-form-target="template">
            <div class="card mb-3 expense-item nested-fields shadow-sm border-danger" data-new-record="true">
              <div class="card-header drag-handle d-flex justify-content-between align-items-center py-1" style="cursor: move;">
                <span class="text-muted small">☰ <%= I18n.t('views.budgets.edit.reorder') %></span>
                <button type="button" class="btn-close btn-close-sm" data-action="click->nested-form#remove" aria-label="Close"></button>
              </div>
              <div class="card-body p-3">
                <div class="row g-2">
                  <div class="col-md-7">
                    <label class="form-label"><%= BudgetItem.human_attribute_name(:name) %></label>
                    <input type="text" name="budget[budget_items_attributes][NEW_RECORD][name]" class="form-control" placeholder="<%= BudgetItem.human_attribute_name(:name) %>" />
                  </div>
                  <div class="col-md-5">
                    <label class="form-label"><%= BudgetItem.human_attribute_name(:amount) %></label>
                    <input type="number" step="0.01" name="budget[budget_items_attributes][NEW_RECORD][amount]" class="form-control" placeholder="<%= BudgetItem.human_attribute_name(:amount) %>" />
                  </div>
                </div>
                <input type="hidden" name="budget[budget_items_attributes][NEW_RECORD][item_type]" value="expense" />
                <input type="hidden" name="budget[budget_items_attributes][NEW_RECORD][position]" value="999" />
                <input type="text" name="budget[budget_items_attributes][NEW_RECORD][category]" class="form-control mt-2" placeholder="<%= BudgetItem.human_attribute_name(:category) %>" list="budget-category-options" />
                <textarea name="budget[budget_items_attributes][NEW_RECORD][description]" class="form-control mt-2" rows="1" placeholder="<%= BudgetItem.human_attribute_name(:description) %>"></textarea>
              </div>
            </div>
          </template>

          <div class="d-flex justify-content-between align-items-center mb-3">
            <h3 class="mb-0 text-danger"><%= I18n.t('views.budgets.edit.expense_section') %></h3>
            <button type="button" class="btn btn-sm btn-outline-danger" data-action="click->nested-form#add">+ <%= I18n.t('views.budgets.edit.add_expense') %></button>
          </div>
          <p class="small text-muted"><%= I18n.t("views.budgets.edit.category_help") %></p>

          <div id="expense-items" data-controller="sortable" data-nested-form-target="container">
            <%= f.simple_fields_for :budget_items do |item_form| %>
              <% if item_form.object.item_type == 'expense' %>
                <div class="card mb-3 expense-item nested-fields shadow-sm border-danger" data-new-record="<%= item_form.object.persisted? ? 'false' : 'true' %>">
                  <div class="card-header drag-handle d-flex justify-content-between align-items-center py-1" style="cursor: move;">
                    <span class="text-muted small">☰ <%= I18n.t('views.budgets.edit.reorder') %></span>
                    <button type="button" class="btn-close btn-close-sm" data-action="click->nested-form#remove" aria-label="Close"></button>
                  </div>
                  <div class="card-body p-3">
                    <div class="row g-2">
                      <div class="col-md-7">
                        <%= item_form.input :name, label: false, placeholder: BudgetItem.human_attribute_name(:name) %>
                      </div>
                      <div class="col-md-5">
                        <%= item_form.input :amount, label: false, as: :decimal, input_html: { step: 0.01 }, placeholder: BudgetItem.human_attribute_name(:amount) %>
                      </div>
                    </div>
                    <%= item_form.input :category, label: false, placeholder: BudgetItem.human_attribute_name(:category), input_html: { list: "budget-category-options" } %>
                    <%= item_form.input :description, label: false, as: :text, input_html: { rows: 1 }, placeholder: BudgetItem.human_attribute_name(:description) %>
                    <%= item_form.input :item_type, as: :hidden, input_html: { value: 'expense' } %>
                    <%= item_form.input :position, as: :hidden %>
                    <%= item_form.input :id, as: :hidden if item_form.object.persisted? %>
                    <%= item_form.input :_destroy, as: :hidden %>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>

      <div class="sticky-bottom bg-white p-3 shadow-lg border-top mt-5 d-flex justify-content-between">
        <%= link_to I18n.t('views.budgets.edit.cancel'), budgets_path, class: "btn btn-secondary" %>
        <%= f.submit I18n.t('views.budgets.edit.submit_create'), class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>

