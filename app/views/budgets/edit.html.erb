<div class="row justify-content-center">
  <div class="col-md-10">
    <h1><%= I18n.t('views.budgets.edit.title') %></h1>
    
    <%= simple_form_for @budget do |f| %>
      <div class="row mb-4">
        <div class="col-md-6">
          <%= f.input :account_id, collection: current_user.accounts, label_method: :name, value_method: :id, include_blank: I18n.t('views.common.none_specific'), selected: @budget.account_id %>
          <%= f.input :name %>
          <%= f.input :periodicity, collection: Budget.translated_periodicities %>
        </div>
        <div class="col-md-6">
          <%= f.input :start_date, as: :date %>
          <%= f.input :end_date, as: :date %>
        </div>
      </div>

      <hr>

      <h3><%= I18n.t('views.budgets.edit.income_section') %></h3>
      
      <div id="income-items" data-controller="sortable"
           data-label-name="<%= BudgetItem.human_attribute_name(:name) %>"
           data-label-amount="<%= BudgetItem.human_attribute_name(:amount) %>"
           data-label-description="<%= BudgetItem.human_attribute_name(:description) %>"
           data-btn-reorder="<%= I18n.t('views.balance_sheets.edit.reorder') %>">
        <%= f.simple_fields_for :budget_items do |item_form| %>
          <% if item_form.object.item_type == 'income' %>
            <div class="card mb-3 income-item nested-fields">
              <div class="card-header drag-handle" style="cursor: move;">
                <span class="text-muted">☰ <%= I18n.t('views.balance_sheets.edit.reorder') %></span>
              </div>
              <div class="card-body">
                <div class="row">
                  <div class="col-md-4">
                    <%= item_form.input :name %>
                  </div>
                  <div class="col-md-4">
                    <%= item_form.input :amount, as: :decimal, input_html: { step: 0.01 } %>
                  </div>
                  <div class="col-md-4">
                    <%= item_form.input :_destroy, as: :boolean, label: I18n.t('views.balance_sheets.show.destroy'), wrapper_html: { class: "mt-4" } if item_form.object.persisted? %>
                    <%= item_form.input :item_type, as: :hidden, input_html: { value: 'income' } %>
                    <%= item_form.input :id, as: :hidden if item_form.object.persisted? %>
                    <%= item_form.input :position, as: :hidden %>
                  </div>
                </div>
                <%= item_form.input :description, as: :text, input_html: { rows: 2 } %>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
      
      <button type="button" class="btn btn-sm btn-outline-success mb-4" id="add-income">+ <%= I18n.t('views.budgets.edit.add_income') %></button>

      <hr>

      <h3><%= I18n.t('views.budgets.edit.expense_section') %></h3>
      
      <div id="expense-items" data-controller="sortable"
           data-label-name="<%= BudgetItem.human_attribute_name(:name) %>"
           data-label-amount="<%= BudgetItem.human_attribute_name(:amount) %>"
           data-label-description="<%= BudgetItem.human_attribute_name(:description) %>"
           data-btn-reorder="<%= I18n.t('views.balance_sheets.edit.reorder') %>">
        <%= f.simple_fields_for :budget_items do |item_form| %>
          <% if item_form.object.item_type == 'expense' %>
            <div class="card mb-3 expense-item nested-fields">
              <div class="card-header drag-handle" style="cursor: move;">
                <span class="text-muted">☰ <%= I18n.t('views.balance_sheets.edit.reorder') %></span>
              </div>
              <div class="card-body">
                <div class="row">
                  <div class="col-md-4">
                    <%= item_form.input :name %>
                  </div>
                  <div class="col-md-4">
                    <%= item_form.input :amount, as: :decimal, input_html: { step: 0.01 } %>
                  </div>
                  <div class="col-md-4">
                    <%= item_form.input :_destroy, as: :boolean, label: I18n.t('views.balance_sheets.show.destroy'), wrapper_html: { class: "mt-4" } if item_form.object.persisted? %>
                    <%= item_form.input :item_type, as: :hidden, input_html: { value: 'expense' } %>
                    <%= item_form.input :id, as: :hidden if item_form.object.persisted? %>
                    <%= item_form.input :position, as: :hidden %>
                  </div>
                </div>
                <%= item_form.input :description, as: :text, input_html: { rows: 2 } %>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
      
      <button type="button" class="btn btn-sm btn-outline-danger mb-4" id="add-expense">+ <%= I18n.t('views.budgets.edit.add_expense') %></button>

      <div class="d-flex justify-content-between mt-4">
        <%= link_to I18n.t('views.budgets.edit.cancel'), @budget, class: "btn btn-secondary" %>
        <%= f.submit I18n.t('views.budgets.edit.submit_update'), class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>

<%= content_for :head do %>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      let incomeIndex = <%= @budget.budget_items.select { |i| i.item_type == 'income' }.size || 0 %> + Date.now();
      let expenseIndex = <%= @budget.budget_items.select { |i| i.item_type == 'expense' }.size || 0 %> + Date.now();

      document.getElementById('add-income')?.addEventListener('click', function() {
        const container = document.getElementById('income-items');
        if (!container) return;
        const labels = container.dataset;

        // Calculate next position
        const currentCount = container.querySelectorAll('.nested-fields').length;
        const nextPosition = currentCount + 1;

        const html = `
          <div class="card mb-3 income-item nested-fields">
            <div class="card-header drag-handle" style="cursor: move;">
              <span class="text-muted">☰ ${labels.btnReorder}</span>
            </div>
            <div class="card-body">
              <div class="row">
                <div class="col-md-4">
                  <label class="form-label">${labels.labelName}</label>
                  <input type="text" name="budget[budget_items_attributes][${incomeIndex}][name]" class="form-control" />
                </div>
                <div class="col-md-4">
                  <label class="form-label">${labels.labelAmount}</label>
                  <input type="number" step="0.01" name="budget[budget_items_attributes][${incomeIndex}][amount]" class="form-control" />
                </div>
              </div>
              <input type="hidden" name="budget[budget_items_attributes][${incomeIndex}][item_type]" value="income" />
              <input type="hidden" name="budget[budget_items_attributes][${incomeIndex}][position]" value="${nextPosition}" />
              <div class="mt-2">
                <label class="form-label">${labels.labelDescription}</label>
                <textarea name="budget[budget_items_attributes][${incomeIndex}][description]" class="form-control" rows="2"></textarea>
              </div>
            </div>
          </div>
        `;
        container.insertAdjacentHTML('beforeend', html);
        incomeIndex++;
      });

      document.getElementById('add-expense')?.addEventListener('click', function() {
        const container = document.getElementById('expense-items');
        if (!container) return;
        const labels = container.dataset;

        // Calculate next position
        const currentCount = container.querySelectorAll('.nested-fields').length;
        const nextPosition = currentCount + 1;

        const html = `
          <div class="card mb-3 expense-item nested-fields">
            <div class="card-header drag-handle" style="cursor: move;">
              <span class="text-muted">☰ ${labels.btnReorder}</span>
            </div>
            <div class="card-body">
              <div class="row">
                <div class="col-md-4">
                  <label class="form-label">${labels.labelName}</label>
                  <input type="text" name="budget[budget_items_attributes][${expenseIndex}][name]" class="form-control" />
                </div>
                <div class="col-md-4">
                  <label class="form-label">${labels.labelAmount}</label>
                  <input type="number" step="0.01" name="budget[budget_items_attributes][${expenseIndex}][amount]" class="form-control" />
                </div>
              </div>
              <input type="hidden" name="budget[budget_items_attributes][${expenseIndex}][item_type]" value="expense" />
              <input type="hidden" name="budget[budget_items_attributes][${expenseIndex}][position]" value="${nextPosition}" />
              <div class="mt-2">
                <label class="form-label">${labels.labelDescription}</label>
                <textarea name="budget[budget_items_attributes][${expenseIndex}][description]" class="form-control" rows="2"></textarea>
              </div>
            </div>
          </div>
        `;
        container.insertAdjacentHTML('beforeend', html);
        expenseIndex++;
      });
    });
  </script>
<% end %>

