<% bs = balance_sheet %>
<div class="card mb-3">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center">
      <div>
        <h6 class="mb-1"><%= l(bs.recorded_at, format: :long) %></h6>
        <small class="text-muted"><%= BalanceSheet.human_attribute_name(:net_worth) %></small>
      </div>
      <div class="text-end">
        <h5 class="mb-0 <%= bs.net_worth >= 0 ? 'text-success' : 'text-danger' %>">
          <%= number_to_currency(bs.net_worth) %>
        </h5>
        <small class="text-muted">
          <%= BalanceSheet.human_attribute_name(:total_assets) %>: <%= number_to_currency(bs.total_assets) %> | 
          <%= BalanceSheet.human_attribute_name(:total_liabilities) %>: <%= number_to_currency(bs.total_liabilities) %>
        </small>
      </div>
    </div>
  </div>
</div>

